<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>CoCreate OS — Early Access</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
</head>
<body style="margin:0;padding:0;background:#0b1022">
<div id="root" style="background:#0b1022;color:#fff;font-family:'Inter',-apple-system,BlinkMacSystemFont,sans-serif;min-height:100vh;overflow-x:hidden;border-radius:12px;position:relative">
<style>
*,*::before,*::after{box-sizing:border-box}
#root::before{content:'';position:absolute;top:-200px;left:50%;transform:translateX(-50%);width:900px;height:600px;background:radial-gradient(ellipse,rgba(245,166,35,0.07) 0%,transparent 70%);pointer-events:none;z-index:0}
.nb{display:flex;justify-content:space-between;align-items:center;padding:16px 28px;background:rgba(11,16,34,0.85);border-bottom:1px solid rgba(255,255,255,0.08);position:relative;z-index:1}
.nb a{color:#fff;text-decoration:none;font-size:13px;font-weight:500;display:flex;align-items:center;gap:8px}
.ba{width:30px;height:30px;border-radius:50%;background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.08);display:grid;place-items:center}
.bd{font-size:11px;font-weight:600;letter-spacing:2px;color:#f5a623;display:flex;align-items:center;gap:6px}
.hr{text-align:center;padding:56px 20px 40px;position:relative;z-index:1}
.hl{width:56px;height:56px;margin:0 auto 28px;background:linear-gradient(135deg,#f5a623,#e08a10);border-radius:14px;display:grid;place-items:center;box-shadow:0 8px 32px rgba(245,166,35,0.25)}
.hr h1{font-size:42px;font-weight:900;line-height:1.1;margin-bottom:16px;letter-spacing:-1px;color:#ffffff}
.hr .su{color:#f5a623;font-size:18px;font-weight:600;line-height:1.5;margin-bottom:20px}
.hr .bt{color:#8a8fa8;font-size:14px;line-height:1.7;max-width:520px;margin:0 auto}
.mn{max-width:1020px;margin:0 auto;padding:24px 20px 64px;display:grid;grid-template-columns:1fr 1fr;gap:40px;align-items:start;position:relative;z-index:1}
.wh h2{font-size:20px;font-weight:700;margin-bottom:20px;color:#ffffff}
.bc{background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.08);border-radius:14px;padding:20px;margin-bottom:14px;display:flex;gap:14px;align-items:flex-start;transition:border-color .25s,transform .25s;cursor:default}
.bc:hover{border-color:rgba(245,166,35,0.25);transform:translateY(-2px)}
.bi{width:44px;height:44px;min-width:44px;border-radius:10px;background:rgba(245,166,35,0.12);display:grid;place-items:center}
.bc h3{font-size:15px;font-weight:700;margin-bottom:4px;color:#ffffff}
.bc p{font-size:13px;color:#8a8fa8;line-height:1.6}
.fc{background:#111732;border:2px dashed rgba(245,166,35,0.35);border-radius:18px;padding:32px 28px 28px;position:relative;overflow:hidden}
.fc::after{content:'';position:absolute;top:-20px;right:-20px;width:80px;height:80px;border:3px solid rgba(245,166,35,0.2);border-radius:50%;pointer-events:none}
.fc::before{content:'';position:absolute;top:10px;right:10px;width:50px;height:50px;border:3px solid rgba(245,166,35,0.15);border-radius:50%;pointer-events:none}
.fc h2{font-size:20px;font-weight:800;margin-bottom:4px;color:#ffffff}
.fs{color:#8a8fa8;font-size:13px;margin-bottom:24px}
.fl{display:block;font-size:11px;font-weight:600;letter-spacing:1.5px;color:#8a8fa8;margin-bottom:7px;text-transform:uppercase}
.fg{margin-bottom:18px}
.fg input{width:100%;padding:12px 14px;background:#1a2040 !important;border:1px solid rgba(255,255,255,0.1) !important;border-radius:9px;color:#fff !important;font-size:14px;font-family:inherit;outline:none;transition:border-color .2s,box-shadow .2s;-webkit-appearance:none;appearance:none}
.fg input:focus{border-color:#f5a623 !important;box-shadow:0 0 0 3px rgba(245,166,35,0.25) !important}
.fg input::placeholder{color:#8a8fa8 !important}
.tg{display:grid;grid-template-columns:1fr 1fr;gap:9px}
.sm{text-align:center;padding:36px 14px;animation:fu .4s ease-out}
.sm .ck{width:52px;height:52px;background:rgba(52,211,153,0.12);border-radius:50%;display:grid;place-items:center;margin:0 auto 14px}
.sm h3{font-size:18px;font-weight:700;margin-bottom:6px;color:#ffffff}
.sm p{color:#8a8fa8;font-size:13px;line-height:1.6}
.em{background:rgba(239,68,68,0.1);border:1px solid rgba(239,68,68,0.25);color:#fca5a5;padding:9px 12px;border-radius:9px;font-size:12px;margin-bottom:14px;animation:fu .3s ease-out}
.ff{text-align:center;margin-top:12px;font-size:11px;color:#8a8fa8;display:flex;align-items:center;justify-content:center;gap:5px}
@keyframes fu{from{opacity:0;transform:translateY(8px)}to{opacity:1;transform:translateY(0)}}
@media(max-width:680px){.mn{grid-template-columns:1fr;gap:28px}.hr{padding:40px 16px 28px}.hr h1{font-size:28px}.fc{padding:24px 18px 20px}.nb{padding:12px 14px}}
</style>

<nav class="nb">
  <!-- FIX: Updated href to "/" so it links back to the Hacker Dojo homepage -->
  <a href="/"><span class="ba"><svg width="12" height="12" viewBox="0 0 14 14" fill="none"><path d="M9 2L4 7l5 5" stroke="#fff" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg></span> Back to Dojo</a>
  <span class="bd"><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg> CLOSED BETA</span>
</nav>

<section class="hr">
  <div class="hl"><svg width="28" height="28" viewBox="0 0 32 32" fill="none"><rect x="6" y="18" width="20" height="4" rx="1.5" fill="#fff" opacity=".9"/><rect x="8" y="12" width="16" height="4" rx="1.5" fill="#fff" opacity=".7"/><rect x="10" y="6" width="12" height="4" rx="1.5" fill="#fff" opacity=".5"/></svg></div>
  <h1>CoCreate OS is coming soon...</h1>
  <p class="su">Join the Closed Beta list. Lock in your username.<br>Get the 24-hour Early Access link.</p>
  <p class="bt">We are currently onboarding Dojo startups and locking down the first batch of micro-contracts. When the gates open, the waitlist gets the link 24 hours before the public.</p>
</section>

<main class="mn">
  <div class="wh">
    <h2>Why join the waitlist?</h2>
    <div class="bc">
      <div class="bi"><svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#f5a623" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="7" width="20" height="14" rx="2"/><path d="M16 3h-8l-2 4h12z"/></svg></div>
      <div><h3>The $1,997 Forge Scholarship</h3><p>One waitlist member will be randomly selected to receive a fully-paid scholarship to The Forge&#8212;our elite 6-week AI Accelerator crucible.</p></div>
    </div>
    <div class="bc">
      <div class="bi"><svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#f5a623" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg></div>
      <div><h3>24-Hour Head Start</h3><p>Get the platform link a full day before public launch. First movers lock the best usernames and early micro-contracts.</p></div>
    </div>
    <div class="bc">
      <div class="bi"><svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#f5a623" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg></div>
      <div><h3>Founding Member Status</h3><p>Shape the platform roadmap. Founding members get priority matching with Dojo startups and early community perks.</p></div>
    </div>
  </div>

  <div class="fc" id="formCard">
    <h2>Request Early Access</h2>
    <p class="fs">Invites roll out in batches. Tell us who you are.</p>
    <div id="errBox" class="em" style="display:none"></div>
    <div id="formArea">
      <div class="fg"><label class="fl">Full Name</label><input type="text" id="fn" placeholder="Your full name"></div>
      <div class="fg"><label class="fl">Email Address</label><input type="email" id="em2" placeholder="you@example.com"></div>
      <div class="fg">
        <label class="fl">I am looking to&#8230;</label>
        <div class="tg">
          <button type="button" id="t1" onclick="si(this)" style="padding:11px 14px;border-radius:9px;font-size:13px;font-weight:600;font-family:inherit;cursor:pointer;text-align:center;background:#f5a623;border:1.5px solid #f5a623;color:#000;transition:all .2s">Build &amp; Earn</button>
          <button type="button" id="t2" onclick="si(this)" style="padding:11px 14px;border-radius:9px;font-size:13px;font-weight:600;font-family:inherit;cursor:pointer;text-align:center;background:transparent;border:1.5px solid rgba(255,255,255,0.2);color:#ffffff;transition:all .2s">Hire Talent</button>
        </div>
      </div>
      <button type="button" id="sbtn" onclick="go()" style="width:100%;padding:14px;margin-top:6px;background:#f5a623;border:none;border-radius:11px;color:#000;font-size:15px;font-weight:700;font-family:inherit;cursor:pointer;transition:background .2s,transform .15s,box-shadow .2s">Join The Waitlist</button>
    </div>
    <p class="ff"><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 8v4M12 16h.01"/></svg> No spam. Just your beta invite.</p>
  </div>
</main>

<script>
var activeIntent='Build & Earn';
function si(b){
  var t1=document.getElementById('t1'),t2=document.getElementById('t2');
  if(b.id==='t1'){
    t1.style.background='#f5a623';t1.style.borderColor='#f5a623';t1.style.color='#000';
    t2.style.background='transparent';t2.style.borderColor='rgba(255,255,255,0.2)';t2.style.color='#ffffff';
    activeIntent='Build & Earn';
  }else{
    t2.style.background='#f5a623';t2.style.borderColor='#f5a623';t2.style.color='#000';
    t1.style.background='transparent';t1.style.borderColor='rgba(255,255,255,0.2)';t1.style.color='#ffffff';
    activeIntent='Hire Talent';
  }
}
function go(){
  var e=document.getElementById('errBox');e.style.display='none';
  var n=document.getElementById('fn').value.trim();
  var m=document.getElementById('em2').value.trim();
  if(!n||!m){e.textContent='Please fill in all fields.';e.style.display='block';return}
  if(!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(m)){e.textContent='Please enter a valid email address.';e.style.display='block';return}
  var b=document.getElementById('sbtn');b.disabled=true;b.textContent='Submitting\u2026';b.style.opacity='0.6';
  fetch('/api/submit',{
    method:'POST',headers:{'Content-Type':'application/json'},
    body:JSON.stringify({fullName:n,email:m,intent:activeIntent})
  }).then(function(r){
    if(!r.ok)throw new Error('f');
  }).then(function(){
    document.getElementById('formCard').innerHTML='<div class="sm"><div class="ck"><svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="#34d399" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg></div><h3>You\u2019re on the list!</h3><p>We\u2019ll send your early access link to <strong>'+m+'</strong> when the gates open.</p></div>';
  }).catch(function(){
    b.disabled=false;b.textContent='Join The Waitlist';b.style.opacity='1';
    e.textContent='Something went wrong. Please try again.';e.style.display='block';
  });
}
</script>
</div>
</body>
</html>
